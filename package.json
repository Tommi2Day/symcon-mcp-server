{
  "name": "symcon-mcp-server",
  "version": "1.0.0",
  "description": "Docker-based MCP Server for IP-Symcon via JSON-RPC API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "coverage": "vitest run --config vitest.config.ts --coverage",
    "coverage:open": "vitest run --config vitest.config.ts --coverage && open coverage/index.html",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "version": "node scripts/bump-version.mjs && git add -A"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
