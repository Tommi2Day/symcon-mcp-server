{
  "name": "symcon-mcp-server",
  "version": "0.0.4",
  "description": "Docker-based MCP Server for IP-Symcon via JSON-RPC API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "coverage": "vitest run --config vitest.config.ts --coverage",
    "coverage:open": "vitest run --config vitest.config.ts --coverage && open coverage/index.html",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "version": "node scripts/bump-version.mjs && git add -A"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "tsx": "^4.16.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
