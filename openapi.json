{
  "openapi": "3.1.0",
  "info": {
    "title": "Symcon MCP Server",
    "description": "Model Context Protocol (MCP) server for IP-Symcon automation systems",
    "version": "0.0.1",
    "contact": {
      "name": "Tommi2Day",
      "url": "https://github.com/Tommi2Day/symcon-mcp-server"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:4096",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Returns the status of the MCP server and its connection to IP-Symcon",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Server is degraded (e.g. Symcon unreachable)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/mcp": {
      "post": {
        "summary": "MCP Streamable HTTP Endpoint",
        "description": "Main entry point for Model Context Protocol using Streamable HTTP transport",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful MCP operation"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/sse": {
      "get": {
        "summary": "MCP SSE Endpoint",
        "description": "Initializes a Server-Sent Events connection for MCP",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "responses": {
          "200": {
            "description": "SSE stream established"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/messages": {
      "post": {
        "summary": "MCP Message Endpoint for SSE",
        "description": "Endpoint to send MCP messages back to the server when using SSE transport",
        "parameters": [
          {
            "name": "sessionId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "responses": {
          "202": {
            "description": "Message accepted"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-mcp-api-key"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ]
          },
          "version": {
            "type": "string"
          },
          "uptime": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "latencyMs": {
            "type": "number"
          },
          "symcon": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "reachable": {
                "type": "boolean"
              },
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
