# ─────────────────────────────────────────────────────────────────────────────
# Symcon MCP Server – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── MCP Server ────────────────────────────────────────────────────────────────
# Port the MCP server listens on inside the container
MCP_PORT=4096

# Port exposed on the Docker host
MCP_HOST_PORT=4096

# Transport protocol: "streamable" (recommended) or "sse" (legacy)
MCP_TRANSPORT=streamable

# Optional API token – clients must send "Authorization: Bearer <token>" or
# "X-MCP-API-Key: <token>". Leave empty to allow unauthenticated access.
MCP_AUTH_TOKEN=

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# ── IP-Symcon Connection ──────────────────────────────────────────────────────
# URL of the Symcon JSON-RPC API
# Examples:
#   Local Symcon on host machine:  http://host.docker.internal:3777/api/
#   Symcon on another machine:     http://192.168.1.100:3777/api/
#   Symcon with HTTPS:             https://symcon.example.com/api/
SYMCON_API_URL=http://host.docker.internal:3777/api/

# Symcon credentials (leave empty if no authentication is configured)
SYMCON_API_USER=
SYMCON_API_PASSWORD=

# Set to "false" to skip TLS certificate verification (for self-signed certs)
SYMCON_TLS_VERIFY=true
